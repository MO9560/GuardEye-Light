<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:spacing="10dp">

        <!-- Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛡️ GuardEye v3.0"
                android:textSize="26sp"
                android:textColor="@color/on_background"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="安卓监控 · AI 识别 · Telegram 告警"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A2A" />

        <!-- Bot Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/edit_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 Bot 状态"
                android:textColor="@color/on_background"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBotStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴 Bot 未启动"
                android:textColor="@color/red"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Bot Token -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bot Token"
            android:textColor="@color/on_background"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="123456789:ABCdef..."
            android:textColor="@color/on_background"
            android:textColorHint="#666"
            android:background="@drawable/edit_bg"
            android:padding="10dp"
            android:inputType="text" />

        <!-- Chat ID -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chat ID"
            android:textColor="@color/on_background"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="8773857995"
            android:textColor="@color/on_background"
            android:textColorHint="#666"
            android:background="@drawable/edit_bg"
            android:padding="10dp"
            android:inputType="text" />

        <!-- Interval Slider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="拍摄间隔"
            android:textColor="@color/on_background"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/sliderInterval"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="9"
                android:progress="4"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <TextView
                android:id="@+id/tvInterval"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="5 分钟"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Switches -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI 识别"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/switchDetection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="@color/primary"
                android:trackTint="@color/primary_dark" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="调试模式"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/switchDebug"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#FF9800"
                android:trackTint="#E65100" />
        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 保存配置"
            android:layout_marginTop="6dp"
            android:backgroundTint="@color/primary" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 启动监控"
            android:backgroundTint="@color/accent"
            android:textColor="#000" />

        <!-- ── Debug Panel ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐛 调试面板"
            android:textColor="#FF9800"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bot: 未启动\nCameraX: 未初始化\n模型: 未加载\nJVM: —\n电量: —"
            android:textColor="#BDBDBD"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="@drawable/edit_bg"
            android:lineSpacingExtra="2dp" />

        <!-- Bot Commands Reference -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Bot 指令\n/start · /stop · /photo · /status\n/interval N · /detect on/off · /debug on/off · /test"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
