<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Bot Token -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="14dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Bot Token"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <EditText
                android:id="@+id/editToken"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="输入 Telegram Bot Token"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:backgroundTint="@color/primary"
                android:inputType="textPassword"
                android:singleLine="true"/>

            <ImageButton
                android:id="@+id/btnToggleToken"
                android:layout_width="36dp" android:layout_height="36dp"
                android:background="@drawable/btn_icon_circle"
                android:src="@drawable/ic_eye_outline"
                app:tint="@color/text_hint"
                android:contentDescription="显隐"
                android:padding="7dp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Chat ID -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="14dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chat ID"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/editChatId"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="输入 Chat ID"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:backgroundTint="@color/primary"
            android:inputType="number"
            android:singleLine="true"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Save button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSettings"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="保存设置"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary"
        app:cornerRadius="12dp"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        android:layout_marginTop="4dp"/>

</LinearLayout>
